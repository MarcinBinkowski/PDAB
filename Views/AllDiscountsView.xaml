<UserControl x:Class="PDAB.Views.AllDiscountsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <ListView ItemsSource="{Binding List}" SelectedItem="{Binding SelectedItem, Mode=TwoWay}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="ID" DisplayMemberBinding="{Binding DiscountId}" Width="50"/>
                    <GridViewColumn Header="Name" DisplayMemberBinding="{Binding DiscountName}" Width="150"/>
                    <GridViewColumn Header="%" DisplayMemberBinding="{Binding DiscountPercentage}" Width="80"/>
                    <GridViewColumn Header="Active" DisplayMemberBinding="{Binding IsActive}" Width="80"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</UserControl>