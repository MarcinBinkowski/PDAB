<UserControl x:Class="PDAB.Views.AllProductImagesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <ListView ItemsSource="{Binding List}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="ID" DisplayMemberBinding="{Binding ProductImageId}" Width="50"/>
                    <GridViewColumn Header="Product" DisplayMemberBinding="{Binding Product.ProductName}" Width="150"/>
                    <GridViewColumn Header="Image URL" DisplayMemberBinding="{Binding ImageUrl}" Width="300"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</UserControl>