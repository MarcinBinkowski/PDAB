<Window x:Class="PDAB.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="PDAB" Height="450" Width="800"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        FontFamily="{materialDesign:MaterialDesignFont}"
        xmlns:views="clr-namespace:PDAB.Views"
        xmlns:viewmodels="clr-namespace:PDAB.ViewModels">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <TextBlock Text="Tables" 
                      FontSize="16" 
                      FontWeight="Bold" 
                      Margin="15,10,10,5"/>

            <StackPanel Grid.Row="1"
                      Background="#F0F0F0" 
                      Margin="5">
                <ItemsControl ItemsSource="{Binding Commands}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding DisplayName}"
                                    Command="{Binding Command}"
                                    Margin="2,3"
                                    Height="24"
                                    HorizontalAlignment="Stretch"
                                    />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Workspace" 
                      FontSize="16" 
                      FontWeight="Bold" 
                      Margin="10,10,10,5"/>

            <StackPanel Grid.Row="1" 
                        Orientation="Horizontal" 
                        Margin="10,0,10,10">
                <Button Content="Add" 
                        Command="{Binding Path=AddNewItemCommand, 
                  Mode=OneWay, 
                  UpdateSourceTrigger=PropertyChanged}"
                        Width="80" 
                        Height="25"/>
                <Button Content="Refresh" 
                        Command="{Binding ActiveWorkspace.RefreshCommand}"
                        Width="80" 
                        Height="25"
                        Margin="0,0,10,0"/>
                <Button Content="Delete"
                        Command="{Binding ActiveWorkspace.DeleteCommand, UpdateSourceTrigger=PropertyChanged}"
                        Width="80"
                        Height="25"
                        Margin="0,0,10,0"/>
            </StackPanel>

            <TabControl Grid.Row="2" 
                        ItemsSource="{Binding Workspaces}"
                        IsSynchronizedWithCurrentItem="True"
                        SelectedItem="{Binding ActiveWorkspace, Mode=TwoWay}"
                        Margin="10,0,10,10">
                <TabControl.Resources>
                    <DataTemplate DataType="{x:Type viewmodels:AllRolesViewModel}">
                        <views:AllRolesView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:AllCategoriesViewModel}">
                        <views:AllCategoriesView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:NewRoleViewModel}">
                        <views:NewRoleView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:NewCategoryViewModel}">
                        <views:NewCategoryView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:AllDiscountsViewModel}">
                        <views:AllDiscountsView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:NewDiscountViewModel}">
                        <views:NewDiscountView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:AllPaymentMethodsViewModel}">
                        <views:AllPaymentMethodsView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:NewPaymentMethodViewModel}">
                        <views:NewPaymentMethodView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:AllOrderStatusViewModel}">
                        <views:AllOrderStatusView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:NewOrderStatusViewModel}">
                        <views:NewOrderStatusView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:AllManufacturersViewModel}">
                        <views:AllManufacturersView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:NewManufacturerViewModel}">
                        <views:NewManufacturerView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:AllCustomersViewModel}">
                        <views:AllCustomersView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:NewCustomerViewModel}">
                        <views:NewCustomerView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:AllEmployeesViewModel}">
                        <views:AllEmployeesView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:NewEmployeeViewModel}">
                        <views:NewEmployeeView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:AllProductsViewModel}">
                        <views:AllProductsView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:NewProductViewModel}">
                        <views:NewProductView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:AllOrdersViewModel}">
                        <views:AllOrdersView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:NewOrderViewModel}">
                        <views:NewOrderView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:AllOrderPaymentsViewModel}">
                        <views:AllOrderPaymentsView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:NewOrderPaymentViewModel}">
                        <views:NewOrderPaymentView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:AllReviewsViewModel}">
                        <views:AllReviewsView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:NewReviewViewModel}">
                        <views:NewReviewView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:AllUsersViewModel}">
                        <views:AllUsersView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:NewUserViewModel}">
                        <views:NewUserView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:AllOrderDetailsViewModel}">
                        <views:AllOrderDetailsView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:NewOrderDetailViewModel}">
                        <views:NewOrderDetailView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:AllProductImagesViewModel}">
                        <views:AllProductImagesView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:NewProductImageViewModel}">
                        <views:NewProductImageView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:AllDiscountProductsViewModel}">
                        <views:AllDiscountProductsView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:NewDiscountProductViewModel}">
                        <views:NewDiscountProductView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodels:OrderProductSelectionViewModel}">
                        <views:OrderProductSelectionView/>
                    </DataTemplate>
                </TabControl.Resources>
                <TabControl.ItemTemplate>
                    <DataTemplate>
                        <DockPanel>
                            <Button DockPanel.Dock="Right" 
                                    Command="{Binding CloseCommand}"
                                    Content="✕"
                                    Width="20"
                                    Height="20"
                                    Margin="5,0,0,0"
                                    Background="Transparent"
                                    BorderThickness="0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="Red"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <TextBlock Text="{Binding DisplayName}" 
                                     VerticalAlignment="Center"/>
                        </DockPanel>
                    </DataTemplate>
                </TabControl.ItemTemplate>
            </TabControl>
        </Grid>
    </Grid>
</Window>