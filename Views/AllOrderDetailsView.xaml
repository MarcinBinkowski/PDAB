<UserControl x:Class="PDAB.Views.AllOrderDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <ListView ItemsSource="{Binding List}" SelectedItem="{Binding SelectedItem}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="ID" DisplayMemberBinding="{Binding OrderDetailId}" Width="50"/>
                    <GridViewColumn Header="Order ID" DisplayMemberBinding="{Binding OrderId}" Width="70"/>
                    <GridViewColumn Header="Product" DisplayMemberBinding="{Binding Product.ProductName}" Width="150"/>
                    <GridViewColumn Header="Quantity" DisplayMemberBinding="{Binding Quantity}" Width="70"/>
                    <GridViewColumn Header="Unit Price" DisplayMemberBinding="{Binding UnitPrice, StringFormat=C}" Width="100"/>
                    <GridViewColumn Header="Discount" DisplayMemberBinding="{Binding Discount.DiscountName}" Width="100"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</UserControl>