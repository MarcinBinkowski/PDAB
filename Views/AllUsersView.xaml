<UserControl x:Class="PDAB.Views.AllUsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <ListView ItemsSource="{Binding List}" SelectedItem="{Binding SelectedItem}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="ID" DisplayMemberBinding="{Binding UserId}" Width="50"/>
                    <GridViewColumn Header="Username" DisplayMemberBinding="{Binding Username}" Width="120"/>
                    <GridViewColumn Header="Employee" DisplayMemberBinding="{Binding Employee.LastName}" Width="120"/>
                    <GridViewColumn Header="Role" DisplayMemberBinding="{Binding Role.RoleName}" Width="100"/>
                    <GridViewColumn Header="Active" DisplayMemberBinding="{Binding IsActive}" Width="60"/>
                </GridView>
            </ListView.View>
        </ListView>
    </Grid>
</UserControl>